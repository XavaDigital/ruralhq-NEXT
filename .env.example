# Copy to .env.local and fill in. With no DATABASE_URL the app runs off the
# committed JSON seed + a local file submission store (no DB needed).

# Canonical site URL (metadata, sitemap, schema.org)
NEXT_PUBLIC_SITE_URL=https://ruralhq.co.nz

# Database — a standard Postgres connection string. Portable: works against
# local Docker, Supabase (use the transaction pooler :6543, IPv4), or AWS RDS.
# SSL is applied automatically for non-local hosts (see src/lib/db.ts).
#   Local Docker:  postgres://postgres:postgres@localhost:55432/postgres
#   Supabase:      postgres://postgres.<ref>:<pw>@aws-<n>-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Anthropic — AI moderation (/api/moderate, /api/listings) and news (/api/news).
# Also run: pnpm add @anthropic-ai/sdk
ANTHROPIC_API_KEY=

# Shared secret required to trigger the news-generation cron endpoint
CRON_SECRET=

# Google AdSense — publisher id like ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT=

# Not required for the direct-Postgres data layer. Only needed if you later add
# Supabase Auth or Storage:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
